SERVER_PORT=8081

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=iicpc
DB_SSLMODE=disable

REDPANDA_BROKERS=localhost:19092

BUILD_TIMEOUT_SECONDS=300
DEPLOY_TIMEOUT_SECONDS=180
HEALTH_PROBE_TIMEOUT_SECONDS=30
IDLE_CONTAINER_TTL_SECONDS=1800
RESTART_ATTEMPTS=1
SANDBOX_NETWORK_MODE=bridge
SANDBOX_BIND_HOST=127.0.0.1
SANDBOX_SERVICE_HOST=localhost

LOG_LEVEL=info
