# Root development defaults. Docker Compose reads infrastructure/docker/.env.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=iicpc
DB_SSLMODE=disable
REDIS_ADDR=localhost:6379
REDPANDA_BROKERS=localhost:19092

SUBMISSION_SERVICE_URL=http://localhost:8080
VALIDATION_SERVICE_URL=http://localhost:8084
ORCHESTRATOR_URL=http://localhost:8081
RATE_LIMIT_PER_MINUTE=600
MAX_BODY_SIZE_MB=64
API_AUTH_TOKEN=
NEXT_PUBLIC_API_URL=http://localhost:8082
NEXT_PUBLIC_WS_URL=ws://localhost:8082

LOG_LEVEL=debug
